---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="JF Self Defense — Singapore"
  description="Practical self defense in Singapore — taught by Jeffrey Fleury, ICPS. Real situational decisions for women, families and professionals. No belts. No forms."
  activeNav="home"
  bodyLabel="01 Home">

<!-- HERO -->
<header class="hero">
  <div class="hero-bg">
    <img src="/assets/hero-home-v3.jpg" alt="" />
  </div>
  <div class="hero-photo-cap"><span>VIGILANCE</span><span>SINGAPORE · AFTER HOURS</span></div>
  <div class="wrap">
    <div class="hero-meta">
      <span class="eyebrow"><span class="dot"></span>SELF DEFENSE · KRAV-INFORMED · SINGAPORE</span>
    </div>

    <h1 class="hero-tag display">
      <span class="hero-tag-pre" data-tagline-l1>When you have to fight,</span>
      <span class="hero-tag-main" data-tagline-l2>FIGHT TO <span class="red em">WIN</span></span>
    </h1>

    <div class="hero-sub">
      <div class="col-left">
        <div class="hero-rule"></div>
        <p class="lede">
          Practical self defense for women, families and professionals — taught by a
          working operator with thirty years inside law enforcement, security, and
          protective services. No belts. No forms. Real situational decisions for the
          life you actually live.
        </p>
        <div class="hero-actions">
          <a class="btn" href="/programmes/">See programmes
            <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
      <div class="col-right">
        <span class="eyebrow"><span class="dot"></span>WHY JF</span>
        <p class="body" style="margin-top:14px;max-width:42ch;">
          Most schools sell technique. Jeffrey sells judgment — the harder, more
          important skill. Every class begins with the question every fight ends with:
          could you have avoided this one altogether?
        </p>
      </div>
    </div>
  </div>
</header>

<!-- CREDENTIALS BANNER -->
<section class="creds">
  <div class="creds-inner">
    <figure class="creds-portrait">
      <img src="/assets/jeffrey-square.jpg" alt="Jeffrey Fleury, founder JF Self Defense" />
      <figcaption>
        <span>JEFFREY FLEURY</span>
      </figcaption>
    </figure>
    <div class="creds-meta">
      <span class="eyebrow"><span class="dot"></span>FOUNDER · MASTER TRAINER</span>
      <h2 class="creds-name">Jeffrey Fleury</h2>
      <p class="creds-tenure">1991 — present · Singapore</p>
      <p class="creds-tagline">"When you have to fight, <span class="red">fight to win</span>."</p>
      <p class="creds-body">
        Jeffrey Fleury, BSc, ICPS — Certified Protection Specialist — has spent his
        working life in law enforcement, private security and protective services.
        He's not a martial arts master selling tradition. He's the operator you'd
        want in the room.
      </p>
      <div class="creds-list">
        <div class="cred-item">
          <div class="num"><span class="red">30+</span></div>
          <div class="label">Years in law enforcement, security &amp; protective services</div>
        </div>
        <div class="cred-item">
          <div class="num">ICPS</div>
          <div class="label">International Certified Protection Specialist</div>
        </div>
        <div class="cred-item">
          <div class="num">BSc</div>
          <div class="label">Bachelor of Science — applied to operator judgment</div>
        </div>
        <div class="cred-item">
          <div class="num">2009</div>
          <div class="label">Year JF Self Defense opened to civilian students</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PHILOSOPHY (the centerpiece) -->
<section class="section philo">
  <div class="wrap">
    <div class="section-head section-head-centered">
      <h2 class="display h2 section-head-title">
        A fight you avoid<br/>is a fight you <span style="color:var(--red);">won</span>
      </h2>
      <p class="lede" style="margin-top:24px;max-width:60ch;">
        Jeffrey teaches a five-step hierarchy in strict order of preference. You only
        move down the list when the option above it is gone.
      </p>
    </div>

    <ol class="philo-flow" aria-label="Five-step decision hierarchy">
      <li class="philo-step">
        <span class="philo-step-num">01</span>
        <span class="philo-step-label">PREFERRED</span>
        <span class="philo-step-title">Don't get <br/>into a fight</span>
      </li>
      <li class="philo-step">
        <span class="philo-step-num">02</span>
        <span class="philo-step-label">&nbsp;</span>
        <span class="philo-step-title">De-escalate</span>
      </li>
      <li class="philo-step">
        <span class="philo-step-num">03</span>
        <span class="philo-step-label">&nbsp;</span>
        <span class="philo-step-title">Create <br/>distance</span>
      </li>
      <li class="philo-step">
        <span class="philo-step-num">04</span>
        <span class="philo-step-label">&nbsp;</span>
        <span class="philo-step-title">Run</span>
      </li>
      <li class="philo-step philo-step-last">
        <span class="philo-step-num">05</span>
        <span class="philo-step-label">LAST RESORT</span>
        <span class="philo-step-title">Fight <br/>to win</span>
      </li>
    </ol>
  </div>
</section>

<!-- PROGRAMMES PREVIEW -->
<section class="section section-tight">
  <div class="wrap">
    <div class="section-head section-head-centered">
      <h2 class="display h2 section-head-title" style="text-align:center;margin:0 auto;">
        Built for the<br/>life you actually live.
      </h2>
      <div style="display:flex;justify-content:center;margin-top:clamp(24px,3vh,36px);">
        <a class="btn" href="/programmes/">
          All programmes
          <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <div class="prog-grid prog-grid-mini">
      <div class="prog prog-mini">
        <h3 class="prog-mini-title">Women's self defense</h3>
        <p class="prog-mini-desc">Real-world scenarios — transit, home, office, after dark.</p>
      </div>
      <div class="prog prog-mini">
        <h3 class="prog-mini-title">Group training</h3>
        <p class="prog-mini-desc">Mixed adult weekly class at the Paya Lebar studio.</p>
      </div>
      <div class="prog prog-mini">
        <h3 class="prog-mini-title">Personalised training</h3>
        <p class="prog-mini-desc">Private 1-on-1, programmed against your routine.</p>
      </div>
      <div class="prog prog-mini">
        <h3 class="prog-mini-title">Corporate workshops</h3>
        <p class="prog-mini-desc">Half- and full-day on-site sessions for teams.</p>
      </div>
      <div class="prog prog-mini">
        <h3 class="prog-mini-title">Kids &amp; families</h3>
        <p class="prog-mini-desc">Confidence and boundaries, in language kids understand.</p>
      </div>
      <div class="prog prog-mini">
        <h3 class="prog-mini-title">Security personnel</h3>
        <p class="prog-mini-desc">Working officers and protective staff. By application.</p>
      </div>
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
<section class="section section-tight" id="testimonials">
  <div class="wrap">
    <div class="section-head section-head-centered">
      <h2 class="display h2 section-head-title" style="margin:0 auto;text-align:center;">
        What students say,<br/>in their own words.
      </h2>
      <p class="lede" style="margin:24px auto 0;max-width:54ch;text-align:center;">
        Twenty-four real students and clients — in their own words. Pannable.
      </p>
    </div>

    <div class="testi-carousel" data-testi-carousel>
      <button class="testi-nav prev" type="button" aria-label="Previous testimonial" data-testi-prev>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>

      <div class="testi-stage">
        <div class="testi-track" data-testi-track>
          <!-- Slides injected by site.js from assets/archive/testimonials.json -->
        </div>
      </div>

      <button class="testi-nav next" type="button" aria-label="Next testimonial" data-testi-next>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg>
      </button>
    </div>

    <div class="testi-dots" data-testi-dots>
      <!-- Dots injected by site.js -->
    </div>

    <div class="testi-meta">
      <span class="mono"><span data-testi-current>01</span> / <span data-testi-total>24</span></span>
      <span class="mono">REAL STUDENTS · REAL WORDS · NO COMPOSITES</span>
    </div>
  </div>
</section>

<!-- CORPORATE CLIENTS -->
<section class="logos">
  <div class="wrap">
    <div class="logos-head">
      <span class="eyebrow"><span class="dot"></span>TRAINING TEAMS AT</span>
      <span class="mono" style="color:var(--ink-3);">Selected clients · 2014 — present</span>
    </div>
    <div class="logos-row">
      <div class="logo-cell"><img src="/assets/logos/suss.png" alt="Singapore University of Social Sciences" /></div>
      <div class="logo-cell"><img class="logo-invert" src="/assets/logos/celanese.png" alt="Celanese" /></div>
      <div class="logo-cell"><span>Sloane Clinic</span></div>
      <div class="logo-cell"><img src="/assets/logos/nhg.png" alt="NHG Health" /></div>
      <div class="logo-cell"><span>Emerson</span></div>
      <div class="logo-cell"><span>Latham &amp; Watkins</span></div>
    </div>
  </div>
</section>

<!-- CONTACT — inline form, page-bottom -->
<section class="contact-section" id="book">
  <div class="wrap">
    <div class="contact-inner">
      <div class="contact-pitch">
        <span class="eyebrow"><span class="dot"></span>BOOK A FREE TRIAL</span>
        <h2>
          Start with a<br/>single class.<br/>
          <span class="red">On the house.</span>
        </h2>
        <p class="body" style="font-size:16px;max-width:42ch;">
          Your first session is free — group, women's, or a 1-on-1 introduction.
          Bring workout gear and water; no prior experience needed. Jeffrey
          personally confirms every booking within 24&nbsp;hours.
        </p>
        <div class="contact-side">
          <div class="contact-side-row">
            <span class="label">STUDIO</span>
            <span class="val">414 Upper Paya Lebar Road, L2 Prestige Point<br/>Singapore 534994</span>
          </div>
          <div class="contact-side-row">
            <span class="label">EMAIL</span>
            <span class="val"><a href="mailto:Jeffrey.f@jfselfdefense.com">Jeffrey.f@jfselfdefense.com</a></span>
          </div>
          <div class="contact-side-row">
            <span class="label">WHATSAPP</span>
            <span class="val"><a href="https://wa.me/6596210576" target="_blank" rel="noopener">+65 9621 0576</a></span>
          </div>
        </div>
      </div>
      <div data-inline-trial-form></div>
    </div>
  </div>
</section>

<!-- FOOTER -->

</BaseLayout>
